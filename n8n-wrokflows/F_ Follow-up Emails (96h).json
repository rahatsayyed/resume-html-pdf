    {
      "parameters": {
        "jsCode": "const thread = $input.first().json\nconst myEmail = $('Set Global Vars').first().json.my_email;\nconst messages = thread.messages || (thread.payload ? [thread] : []);\n\n// Sort by date ascending to ensure correct order\nconst sorted = [...messages].sort((a, b) => \n  parseInt(a.internalDate) - parseInt(b.internalDate)\n);\n\n// Skip the first message (your outreach), check the rest for a reply from someone else\nconst hasReply = sorted.slice(1).some(msg => {\n  const headers = msg.payload?.headers || msg.payload?.parts?.[0]?.headers || [];\n  const fromHeader = headers.find(h => h.name?.toLowerCase() === 'from')?.value || '';\n  const from = fromHeader || msg.From || msg.from || '';\n  return from && !from.toLowerCase().includes(myEmail.toLowerCase());\n});\n\nreturn [{ json: { \n  hasReply, \n  contact_id: $('Set FU2 Contact').first().json.contact_id, \n  contact_name: $('Set FU2 Contact').first().json.contact_name, \n  thread_id: $('Set FU2 Contact').first().json.thread_id, \n  email_raw: $('Set FU2 Contact').first().json.email_raw, \n  job_id: $('Set FU2 Contact').first().json.job_id \n} }];"
      },
