    {
      "parameters": {
        "jsCode": "const now = Date.now();\nconst ninetyHours = 96 * 60 * 60 * 1000;\nconst fortyEightHours = 48 * 60 * 60 * 1000;\n\nreturn $input.all().filter(item => {\n  const followupSentAt = item.json.followup1_sent_at;\n  if (!followupSentAt) return false;\n  const sent = new Date(followupSentAt).getTime();\n  return (now - sent) >= fortyEightHours;\n}).map(item => ({ json: item.json }));"
      },
