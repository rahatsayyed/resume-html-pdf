    {
      "parameters": {
        "jsCode": "const rawItems = $input.all();\n// Only consider real job rows (Supabase returns one empty item when alwaysOutputData and 0 rows)\nconst jobs = rawItems.filter(item => item.json && item.json.id != null);\nconst currentJobId = $('Set Job Details').first().json.job_id;\nconst currentCompanyUrl = $('Set Job Details').first().json.company_url;\n\n// No company_url means we cannot do a company match\nif (!currentCompanyUrl || !String(currentCompanyUrl).trim()) {\n  return [{ json: { hasCompanyContacts: false, jobIds: [], jobIdsStr: '' } }];\n}\n\n// Exclude current job (query already does id neq; this is safety)\nconst otherJobs = jobs.filter(item => item.json.id !== currentJobId);\n\nif (otherJobs.length === 0) {\n  return [{ json: { hasCompanyContacts: false, jobIds: [], jobIdsStr: '' } }];\n}\n\nconst jobIds = otherJobs.map(j => String(j.json.id));\nreturn [{ json: { hasCompanyContacts: true, jobIds, jobIdsStr: jobIds.join(',') } }];"
      },
