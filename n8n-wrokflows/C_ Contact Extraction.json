    {
      "parameters": {
        "jsCode": "const companyContacts = $('Fetch Company Contacts').all();\nconst currentJobContacts = $('Fetch Current Job Contacts').all();\nconst currentJobId = $('Set Job Details').first().json.job_id;\n\n// Build set of linkedin profiles already linked to current job\nconst existingLinkedins = new Set(\n  currentJobContacts\n    .map(item => item.json.linkedin)\n    .filter(l => l && String(l).trim())\n    .map(l => String(l).trim().toLowerCase())\n);\n\n// Dedupe company contacts by linkedin; skip those already in current job\nconst seenLinkedins = new Set();\nconst newContacts = [];\n\nfor (const item of companyContacts) {\n  const linkedin = item.json.linkedin;\n  if (!linkedin || !String(linkedin).trim()) continue;\n  const key = String(linkedin).trim().toLowerCase();\n  if (seenLinkedins.has(key)) continue;\n  if (existingLinkedins.has(key)) continue;\n  seenLinkedins.add(key);\n  newContacts.push({\n    json: {\n      _skip: false,\n      job_id: currentJobId,\n      name: item.json.name || '',\n      linkedin: item.json.linkedin,\n      email: Array.isArray(item.json.email) ? item.json.email : (item.json.email ? [String(item.json.email)] : []),\n      email_sent_at: null,\n      email_thread_id: null,\n      followup1_sent_at: null,\n      followup2_sent_at: null,\n      reply_received: false\n    }\n  });\n}\n\nif (newContacts.length === 0) {\n  return [{ json: { _skip: true } }];\n}\n\nreturn newContacts;"
      },
