    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const it of $input.all()) {\n  const results = it.json.results || [];\n  for (const j of results) {\n    out.push({ json: {\n      id: 'adzuna:' + (j.id ?? ''),\n      job_title: j.title ?? null,\n      job_description: j.description ?? null,\n      job_url: j.redirect_url ?? null,\n      company_name: (j.company && j.company.display_name) ? j.company.display_name : null,\n      company_url: null,\n      seniority_level: null,\n      employment_type: j.contract_time ?? null,\n      time_posted: j.created ?? null,\n      apply_url: j.redirect_url ?? null,\n      job_poster_name: null,\n      job_poster_profile_url: null,\n      source: 'adzuna',\n      apply_type: 'external'\n    }});\n  }\n}\nreturn out;"
      },
      "id": "norm_adzuna",
      "name": "Normalize Adzuna",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-624, -128]
    },
    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const it of $input.all()) {\n  const jobs = it.json.jobs || [];\n  for (const j of jobs) {\n    out.push({ json: {\n      id: 'remotive:' + (j.id ?? ''),\n      job_title: j.title ?? null,\n      job_description: j.description ?? null,\n      job_url: j.url ?? null,\n      company_name: j.company_name ?? null,\n      company_url: null,\n      seniority_level: null,\n      employment_type: j.job_type ?? null,\n      time_posted: j.publication_date ?? null,\n      apply_url: j.url ?? null,\n      job_poster_name: null,\n      job_poster_profile_url: null,\n      source: 'remotive',\n      apply_type: 'external'\n    }});\n  }\n}\nreturn out;"
      },
      "id": "norm_remotive",
      "name": "Normalize Remotive",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-624, 112]
    },
    {
      "parameters": {
        "jsCode": "const extra = ($('Config').first().json.remoteokKeyword || '').trim().toLowerCase();\nconst kws = ['react','node','typescript','javascript','frontend','front end','full stack','fullstack','full-stack','software engineer','web developer','backend','next.js','nextjs'];\nif (extra) { for (const t of extra.split(',')) { const s = t.trim().toLowerCase(); if (s) kws.push(s); } }\nconst items = $input.all();\nlet jobs = [];\nif (items.length === 1 && Array.isArray(items[0].json)) {\n  jobs = items[0].json;\n} else {\n  jobs = items.map(i => i.json);\n}\nconst out = [];\nfor (const j of jobs) {\n  if (!j || (!j.id && !j.position)) continue;\n  const hay = ((j.position || '') + ' ' + (Array.isArray(j.tags) ? j.tags.join(' ') : '')).toLowerCase();\n  if (kws.length && !kws.some(k => hay.includes(k))) continue;\n  out.push({ json: {\n    id: 'remoteok:' + (j.id ?? j.slug ?? ''),\n    job_title: j.position ?? null,\n    job_description: j.description ?? null,\n    job_url: j.url ?? null,\n    company_name: j.company ?? null,\n    company_url: j.company_url ?? null,\n    seniority_level: null,\n    employment_type: null,\n    time_posted: j.date ?? null,\n    apply_url: j.apply_url ?? j.url ?? null,\n    job_poster_name: null,\n    job_poster_profile_url: null,\n    source: 'remoteok',\n    apply_type: 'external'\n  }});\n}\nreturn out;"
      },
      "id": "norm_remoteok",
