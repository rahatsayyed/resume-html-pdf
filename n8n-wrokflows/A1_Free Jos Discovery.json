    },
    {
      "parameters": {
        "jsCode": "const rows = $('Collect').first().json.rows || [];\nconst existing = $input.all().map(i => i.json).filter(x => x && x.id);\nconst existingIds = new Set(existing.map(x => x.id));\nconst newRows = rows.filter(r => !existingIds.has(r.id));\nconst total = rows.length;\nconst newCount = newRows.length;\nconst skipped = total - newCount;\nreturn [{ json: { total, newCount, skipped, newRows } }];"
      },
      "id": "e9a69193-944b-43a8-9b30-ee7a8624224a",
