    {
      "parameters": {
        "jsCode": "const contact = $('Set Contact Details').first().json;\nconst raw = contact.contact_email_raw;\n\nlet emails = [];\ntry {\n  const parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  if (Array.isArray(parsed)) {\n    emails = parsed.filter(e => typeof e === 'string' && e.includes('@'));\n  } else if (typeof parsed === 'string' && parsed.includes('@')) {\n    emails = [parsed];\n  }\n} catch (e) {\n  if (typeof raw === 'string' && raw.includes('@')) {\n    emails = [raw];\n  }\n}\n\nif (emails.length === 0) {\n  return [{ json: { skip: true, reason: 'No valid email address' } }];\n}\n\nreturn [{ json: {\n  skip: false,\n  to_email: emails[0],\n  ccEmails: emails.slice(1),\n  contact_id: contact.contact_id,\n  contact_name: contact.contact_name,\n  job_id: contact.job_id\n} }];"
      },
