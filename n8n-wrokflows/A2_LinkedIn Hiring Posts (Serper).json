      "id": "cfg",
      "name": "Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1120, 112]
    },
    {
      "parameters": {
        "jsCode": "const c = $input.first().json;\nconst roles = c.roleTerms || 'software engineer';\nconst gl = c.serperGl || 'us';\nconst num = Number(c.serperNum || 20);\nconst geo = gl === 'in' ? 'india' : '';\nconst queries = [\n  `site:linkedin.com/posts (\"we're hiring\" OR \"we are hiring\" OR \"I'm hiring\") (${roles}) ${geo}`.trim(),\n  `site:linkedin.com/posts (\"join our team\" OR \"now hiring\" OR \"hiring alert\") (\"software engineer\" OR \"developer\") (${roles})`.trim(),\n  `site:linkedin.com/posts (\"#hiring\" OR \"#nowhiring\") (${roles}) (remote OR ${geo || 'usa'})`.trim()\n];\nreturn queries.map(q => ({ json: { q, num, gl } }));"
      },
      "id": "build_queries",
      "name": "Build Queries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-880, 112]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://google.serper.dev/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-KEY",
              "value": "={{ $('Config').first().json.serperApiKey }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ q: $json.q, num: $json.num, gl: $json.gl }) }}",
        "options": {}
      },
      "id": "http_serper",
      "name": "Serper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-624, 112],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const it of $input.all()) {\n  const j = it.json || {};\n  const q = (j.searchParameters && j.searchParameters.q) || null;\n  const organic = j.organic || [];\n  for (const o of organic) {\n    const link = (o.link || '').split('?')[0];\n    if (!link || !link.includes('linkedin.com/posts')) continue;\n    let poster = null;\n    const t = o.title || '';\n    const m = t.match(/^(.*?)\\s+on LinkedIn/i);\n    if (m) poster = m[1].trim();\n    out.push({ json: {\n      id: link,\n      post_url: link,\n      title: o.title ?? null,\n      snippet: o.snippet ?? null,\n      poster_name: poster,\n      poster_profile_url: null,\n      company_name: null,\n      query: q,\n      keywords: null,\n      status: 'new'\n    }});\n  }\n}\nreturn out;"
      },
      "id": "norm_posts",
      "name": "Normalize Posts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-368, 112]
    },
