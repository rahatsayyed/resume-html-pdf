        "chatId": "1125208540",
        "text": "=LinkedIn hiring-post dorks ✅\nNew saved: {{ $json.newCount }}\nAlready existed (skipped): {{ $json.skipped }}\nTotal found this run: {{ $json.total }}",
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "id": "notify",
      "name": "Notify (Telegram)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [448, 208],
      "webhookId": "460aa4f0-7524-44e5-b0fa-9419639baeb9",
      "credentials": {
        "telegramApi": {
          "id": "zR5TTxftQEm2MYTo",
          "name": "Job Automation Bot"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst ids = rows.map(r => r.id).filter(Boolean);\nconst q = ids.map(id => '\"' + String(id).replace(/\"/g, '') + '\"').join(',');\nconst filter = ids.length ? ('id=in.(' + q + ')') : 'id=eq.__none__';\nreturn [{ json: { rows, filter, total: rows.length } }];"
      },
      "id": "fadd3e20-3ae3-438e-a9a4-8c32fa15a551",
      "name": "Collect",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-160, 112]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "hiring_posts",
        "returnAll": true,
        "filterType": "string",
        "filterString": "={{ $json.filter }}"
      },
      "id": "a6c31ff4-61cb-4a88-b3e4-d8c49153a1e1",
      "name": "Fetch Existing",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [48, 112],
      "alwaysOutputData": true,
      "credentials": {
        "supabaseApi": {
          "id": "UgJZt2YIwF9raxzT",
          "name": "Supabase account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const rows = $('Collect').first().json.rows || [];\nconst existing = $input.all().map(i => i.json).filter(x => x && x.id);\nconst existingIds = new Set(existing.map(x => x.id));\nconst newRows = rows.filter(r => !existingIds.has(r.id));\nconst total = rows.length;\nconst newCount = newRows.length;\nconst skipped = total - newCount;\nreturn [{ json: { total, newCount, skipped, newRows } }];"
      },
