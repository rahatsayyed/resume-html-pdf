    {
      "parameters": {
        "sendTo": "={{ $json.to_email }}",
        "subject": "=Following up — {{ $json.job_title }} at {{ $json.company_name }}",
        "emailType": "text",
        "message": "=Hi {{ $('Set FU1 Contact').first().json.contact_name }},\n\nI wanted to follow up on my previous message about the {{ $json.job_title }} role at {{ $json.company_name }}. I'm still very interested in this opportunity and would love to connect.\n\nIf you have a few minutes to chat, I'd be happy to discuss how my experience could be a great fit for your team.\n\nLinkedIn: {{ $('Set Global Vars').first().json.linkedinLink }}\nPortfolio: {{ $('Set Global Vars').first().json.portfolioLink }}\n\nLooking forward to hearing from you!\n\nBest regards,\nRahat Sayyed",
        "options": {
          "appendAttribution": false,
          "ccList": "={{ $json.ccEmails.join(',') }}"
        }
      },
